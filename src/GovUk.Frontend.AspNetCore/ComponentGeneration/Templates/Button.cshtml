@inherits GovUkComponentView<ButtonOptions>

@{
    var classes = Classes("govuk-button", Model.Classes, Model.IsStartButton == true ? "govuk-button--start" : null);
    var element = Model.Element?.ToHtmlString(HtmlEncoder).ToLower() ??
        (Model.Href is not null ? "a" : "button");

    async Task RenderStartIcon()
    {
        <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"/>
        </svg>
    }

    var commonAttributes = new AttributeCollection
    {
        new AttributeCollection.Attribute("class", classes),
        new AttributeCollection.Attribute("data-module", "govuk-button")
    };
    if (Model.Attributes is not null)
    {
        commonAttributes.AddRange(Model.Attributes);
    }
    if (Model.Id is not null)
    {
        commonAttributes.Add("id", Model.Id);
    }

    var buttonAttributes = new AttributeCollection();
    if (Model.Name is not null)
    {
        buttonAttributes.Add("name", Model.Name);
    }
    if (Model.Disabled == true)
    {
        buttonAttributes.AddBoolean("disabled");
        buttonAttributes.Add("aria-disabled", "true");
    }
    if (Model.PreventDoubleClick is not null)
    {
        buttonAttributes.Add("data-prevent-double-click", Model.PreventDoubleClick is true ? "true" : "false");
    }

    if (element == "a")
    {
        <a href="@(Model.Href ?? "#")" role="button" draggable="false" _gfa-attributes="@commonAttributes">
            @HtmlOrText(Model.Html, Model.Text)
            @if (Model.IsStartButton == true)
            {
                await RenderStartIcon();
            }
        </a>
    }
    else if (element == "button")
    {
        <button value="@Model.Value" type="@(Model.Type ?? "submit")" _gfa-attributes="@AttributeCollection.Join(buttonAttributes, commonAttributes)">
            @HtmlOrText(Model.Html, Model.Text)
            @if (Model.IsStartButton == true)
            {
                await RenderStartIcon();
            }
        </button>
    }
    else if (element == "input")
    {
        <input value="@Model.Text" type="@(Model.Type ?? "submit")" _gfa-attributes="@AttributeCollection.Join(buttonAttributes, commonAttributes)" />
    }
}
