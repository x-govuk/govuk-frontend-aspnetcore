@inherits GovUkComponentView<PasswordInputOptions>

@{
    var id = Model.Id ?? Model.Name;

    var attributes = new AttributeCollection
    {
        { "data-module", "govuk-password-input" }
    };
    attributes.AddI18n("show-password", Model.ShowPasswordText);
    attributes.AddI18n("hide-password", Model.HidePasswordText);
    attributes.AddI18n("show-password-aria-label", Model.ShowPasswordAriaLabelText);
    attributes.AddI18n("hide-password-aria-label", Model.HidePasswordAriaLabelText);
    attributes.AddI18n("password-shown-announcement", Model.PasswordShownAnnouncementText);
    attributes.AddI18n("password-hidden-announcement", Model.PasswordHiddenAnnouncementText);
    attributes.AddRange(Model.FormGroup?.Attributes);

    var buttonHtml = new HtmlContentBuilder();
}

<_gfa-capture to="buttonHtml">
    @{
        var buttonAttributes = new AttributeCollection
        {
            { "aria-controls", id ?? string.Empty },
            { "aria-label", Model.ShowPasswordAriaLabelText ?? "Show password" }
        };
        buttonAttributes.AddBoolean("hidden");

        await Html.RenderPartialAsync("./Button.cshtml", new ButtonOptions
        {
            Type = "button",
            Classes = Classes("govuk-button--secondary govuk-password-input__toggle govuk-js-password-input-toggle", Model.Button?.Classes).ToTemplateString(),
            Text = Model.ShowPasswordText ?? "Show",
            Attributes = buttonAttributes
        });
    }

    @HtmlOrText(Model.FormGroup?.AfterInput?.Html, Model.FormGroup?.AfterInput?.Text)
</_gfa-capture>

@{
    await Html.RenderPartialAsync("./Input.cshtml", new InputOptions
    {
        FormGroup = new InputFormGroupOptions
        {
            Classes = Classes("govuk-password-input", Model.FormGroup?.Classes).ToTemplateString(),
            Attributes = attributes,
            BeforeInput = Model.FormGroup?.BeforeInput,
            AfterInput = new AfterInputOptions()
            {
                Html = buttonHtml.ToTemplateString()
            }
        },
        InputWrapper = new InputOptionsInputWrapper()
        {
            Classes = "govuk-password-input__wrapper"
        },
        Label = Model.Label,
        Hint = Model.Hint,
        Classes = Classes("govuk-password-input__input", "govuk-js-password-input-input", Model.Classes).ToTemplateString(),
        ErrorMessage = Model.ErrorMessage,
        Id = id,
        Name = Model.Name,
        Type = "password",
        Spellcheck = false,
        AutoCapitalize = "none",
        AutoComplete = Model.AutoComplete ?? "current-password",
        Value = Model.Value,
        Disabled = Model.Disabled,
        DescribedBy = Model.DescribedBy,
        Attributes = Model.Attributes
    });
}
