@inherits GovUkComponentView<FooterOptions>

@{
    var rebrand = Model.Rebrand ?? false;
}

<footer class="@Classes("govuk-footer", Model.Classes)" _gfa-attributes="Model.Attributes">
    <div class="@Classes("govuk-width-container", Model.ContainerClasses)">
        @if (rebrand)
        {
            await Html.RenderPartialAsync("./Logo.cshtml", new LogoOptions
            {
                Classes = "govuk-footer__crown",
                Rebrand = true,
                UseLogotype = false
            });
        }
        @if (Model.Navigation?.Count > 0)
        {
            <div class="govuk-footer__navigation">
                @foreach (var nav in Model.Navigation)
                {
                    <div class="@Classes("govuk-footer__section", $"govuk-grid-column-{nav.Width ?? "full"}")" _gfa-attributes="nav.Attributes">
                        <h2 class="govuk-footer__heading govuk-heading-m" _gfa-attributes="nav.TitleAttributes">@nav.Title</h2>
                        @if (nav.Items?.Count > 0)
                        {
                            var listClasses = nav.Columns > 0 ? $"govuk-footer__list--columns-{nav.Columns}" : null;
                            <ul class="@Classes("govuk-footer__list", listClasses)" _gfa-attributes="@nav.ItemsAttributes">
                                @foreach (var item in nav.Items)
                                {
                                    if (item.Href is not null && item.Text is not null)
                                    {
                                        <li class="@Classes("govuk-footer__list-item")" _gfa-attributes="item.ItemAttributes">
                                            <a class="govuk-footer__link" href="@item.Href" _gfa-attributes="item.Attributes">
                                                @HtmlOrText(item.Html, item.Text)
                                            </a>
                                        </li>
                                    }
                                }
                            </ul>
                        }
                    </div>
                }
            </div>
            <hr class="govuk-footer__section-break">
        }
        <div class="govuk-footer__meta">
            <div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
                @if (Model.Meta is not null)
                {
                    <h2 class="govuk-visually-hidden">@(Model.Meta.VisuallyHiddenTitle ?? "Support links")</h2>
                    @if (Model.Meta.Items?.Count > 0)
                    {
                        <ul class="@Classes("govuk-footer__inline-list")" _gfa-attributes="Model.Meta.ItemsAttributes">
                            @foreach (var item in Model.Meta.Items)
                            {
                                <li class="@Classes("govuk-footer__inline-list-item")" _gfa-attributes="item.ItemAttributes">
                                    <a class="govuk-footer__link" href="@item.Href" _gfa-attributes="item.Attributes">
                                        @HtmlOrText(item.Html, item.Text)
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    if (Model.Meta.Text is not null || Model.Meta.Html is not null)
                    {
                        <div class="govuk-footer__meta-custom" _gfa-attributes="Model.Meta.ContentAttributes">
                            @HtmlOrText(Model.Meta.Html, Model.Meta.Text)
                        </div>
                    }
                }
                <svg
                    aria-hidden="true"
                    focusable="false"
                    class="govuk-footer__licence-logo"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 483.2 195.7"
                    height="17"
                    width="41">
                    <path
                        fill="currentColor"
                        d="M421.5 142.8V.1l-50.7 32.3v161.1h112.4v-50.7zm-122.3-9.6A47.12 47.12 0 0 1 221 97.8c0-26 21.1-47.1 47.1-47.1 16.7 0 31.4 8.7 39.7 21.8l42.7-27.2A97.63 97.63 0 0 0 268.1 0c-36.5 0-68.3 20.1-85.1 49.7A98 98 0 0 0 97.8 0C43.9 0 0 43.9 0 97.8s43.9 97.8 97.8 97.8c36.5 0 68.3-20.1 85.1-49.7a97.76 97.76 0 0 0 149.6 25.4l19.4 22.2h3v-87.8h-80l24.3 27.5zM97.8 145c-26 0-47.1-21.1-47.1-47.1s21.1-47.1 47.1-47.1 47.2 21 47.2 47S123.8 145 97.8 145"
                    />
                </svg>
                <span class="govuk-footer__licence-description" _gfa-attributes="@Model.ContentLicence?.Attributes">
                    @if (Model.ContentLicence?.Html is not null || Model.ContentLicence?.Text is not null)
                    {
                        @HtmlOrText(Model.ContentLicence.Html, Model.ContentLicence.Text)
                    }
                    else
                    {
                        <text>All content is available under the
                            <a
                                class="govuk-footer__link"
                                href="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"
                                rel="license"
                                _gfa-attributes="Model.ContentLicence?.Attributes">
                                Open Government Licence v3.0
                            </a>,
                            except where otherwise stated
                        </text>
                    }
                </span>
            </div>
            <div class="govuk-footer__meta-item">
                <a
                    class="govuk-footer__link govuk-footer__copyright-logo"
                    href="https://www.nationalarchives.gov.uk/information-management/re-using-public-sector-information/uk-government-licensing-framework/crown-copyright/">
                    @if (Model.Copyright?.Html is not null || Model.Copyright?.Text is not null)
                    {
                        @HtmlOrText(Model.Copyright!.Html, Model.Copyright.Text)
                    }
                    else
                    {
                        <text>© Crown copyright</text>
                    }
                </a>
            </div>
        </div>
    </div>
</footer>
